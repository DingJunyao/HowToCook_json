  "steps": [
    {
      "step": 1,
      "content": "凉粉改刀切麻将块大小",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "开小火，起锅烧油，锅烧微热后，下入蒜末爆香后加入豆瓣酱炒出红油",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "将凉粉块下入锅中，翻炒 10 秒",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入生抽提味，老抽上色，翻炒均匀后加入辣椒面继续翻炒均匀",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入食盐、十三香继续翻炒 10 秒",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "加入准备好的矿泉水，再次翻炒 10 秒，待汤汁浓稠后，关火出锅装盘",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "撒上葱花即可完成",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "选择凉粉时最好选用豌豆淀粉制作成的凉粉，条件不允许的话红薯淀粉或其他也可"
  ]
