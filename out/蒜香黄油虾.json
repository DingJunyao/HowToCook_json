  "steps": [
    {
      "step": 1,
      "content": "大虾去头去壳留尾，用牙签挑去虾线，洗净后用厨房纸吸干水分",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "大蒜切成蒜末，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "中火加热平底锅，放入 5ml 橄榄油",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "油热后放入大虾，每面煎 1-1.5 分钟至变色，取出备用",
      "duration_minutes": 3,
      "tips": "煎至两面变色即可，不要过度煎制"
    },
    {
      "step": 5,
      "content": "同一锅中加入黄油，融化后放入蒜末，小火炒香（约 30 秒）",
      "duration_minutes": 1,
      "tips": "小火避免蒜末焦糊"
    },
    {
      "step": 6,
      "content": "如使用白葡萄酒，此时加入并煮至酒精挥发（约 1 分钟）",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "将虾放回锅中，与蒜香黄油酱汁翻炒均匀（约 1 分钟）",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "挤入柠檬汁，翻炒均匀后立即关火",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 9,
      "content": "装盘，淋上锅中剩余酱汁",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "虾不宜过度烹饪，否则会变硬"
  ]
}