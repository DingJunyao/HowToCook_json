  "steps": [
    {
      "step": 1,
      "content": "食材准备：胡萝卜去头尾，去皮，滚刀切；洋葱剥去外层去芯，切成月牙状；土豆去皮、切大块；肉切块状；剥蒜拍平切碎；咖喱块切碎，增加接触面积加速溶解",
      "duration_minutes": 10,
      "tips": "可以同时进行，提高效率"
    },
    {
      "step": 2,
      "content": "热油锅放入蒜和肉，快速翻炒至肉表面变白",
      "duration_minutes": 2,
      "tips": "保持大火快速翻炒"
    },
    {
      "step": 3,
      "content": "加入胡萝卜，快速翻炒至均匀受热",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入洋葱，快速翻炒至洋葱变透明状",
      "duration_minutes": 2,
      "tips": "洋葱变透明说明已炒软"
    },
    {
      "step": 5,
      "content": "加入土豆，保持翻炒至土豆变软（可以用筷子确认）",
      "duration_minutes": 2,
      "tips": "土豆变软后再加水"
    },
    {
      "step": 6,
      "content": "加水没过所有食材，沸腾后等待15分钟",
      "duration_minutes": 15,
      "tips": "等待过程中可以准备其他食材或制作煎蛋"
    },
    {
      "step": 7,
      "content": "关火，加咖喱并搅拌",
      "duration_minutes": 1,
      "tips": "确保咖喱块完全溶解"
    },
    {
      "step": 8,
      "content": "等待咖喱融化后再开火，缓慢搅拌10分钟，防止糊锅",
      "duration_minutes": 10,
      "tips": "搅拌时要慢，防止糊锅，同时观察水位"
    },
    {
      "step": 9,
      "content": "在外观呈粘稠状态关火结束制作",
      "duration_minutes": 1,
      "tips": "关火后可以盖盖焖一下让味道更融合"
    }
  ],
  "tips": [
    "步骤1-6可以在步骤6的等待过程进行，在这个过程也可以用清水锅煮些蔬菜，或做个煎蛋",
    "步骤6到步骤7之间，需要注意观察沸腾的水位线，如发现低于2/3的食材应加热水至没过食材",
    "做好的咖喱在冰箱冷藏后风味更佳，不用担心一个人吃不完",
    "冷藏的咖喱每次取出需要吃的份量，加热后盖在米饭上"
  ]
}