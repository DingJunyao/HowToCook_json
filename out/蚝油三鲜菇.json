  "steps": [
    {
      "step": 1,
      "content": "蟹味菇、白玉菇去掉根部泥土，掰散菌朵",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "香菇切片（每片厚度0.5-1cm，厚点相对薄点更有嚼劲）",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "生粉倒入小碗中，加入50ml水，搅拌生粉直至融化没有颗粒（即水淀粉）备用",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "水开，放入西蓝花，清水煮3分钟，放入碗中备用",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 5,
      "content": "洗锅烧开水，加入5g食用盐，倒入蟹味菇、白玉菇、香菇，水煮1分钟",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "1分钟后，捞出沥干水分",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "起锅烧油，待油开始冒小泡，放入姜末、小米辣、菜椒煸炒30秒",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "倒入三鲜菇，然后依次倒入生抽、蚝油、鸡精，翻炒均匀后，倒入水淀粉",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "中火烧干汁，加入料酒、葱花出锅",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 10,
      "content": "摆上西蓝花",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": []
