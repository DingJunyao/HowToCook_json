  "steps": [
    {
      "step": 1,
      "content": "锡纸盘里打入鸡蛋 2 个，加入红柚果肉 20g",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "锡纸盘中倒入 15ml 油并摇晃锡纸盘使其均匀覆盖盘底",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "锡纸盘中放入 10g 糖，以及 40g 面粉和 40ml 水",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "用筷子顺时针方向搅拌至淡黄色糊状",
      "duration_minutes": 2,
      "tips": "糊状指没有面粉疙瘩且整体颜色均匀"
    },
    {
      "step": 5,
      "content": "锡纸盘中放入 5g 糖，以及 40g 面粉和 40ml 水",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "继续用筷子搅拌至淡黄色糊状",
      "duration_minutes": 2,
      "tips": "糊状指没有面粉疙瘩且整体颜色均匀"
    },
    {
      "step": 7,
      "content": "锡纸盘放入空气炸锅的烤篮上，用 180 摄氏度烤 15 分钟",
      "duration_minutes": 15,
      "tips": null
    },
    {
      "step": 8,
      "content": "打开空气炸锅，小心取出锡纸盘，用筷子或勺子将蛋糕翻面",
      "duration_minutes": 2,
      "tips": "刚出锅的锡纸盘比较烫，请用夹子夹取或使用湿抹布之类的隔热材料拿取"
    },
    {
      "step": 9,
      "content": "继续 180 摄氏度烤 8 分钟",
      "duration_minutes": 8,
      "tips": null
    },
    {
      "step": 10,
      "content": "取出即可食用",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "如果喜欢较甜的口感可以增加 10g 糖",
    "红柚果肉可以酌情添加，但每份最好不超过 40g 以免影响成品观感",
    "糊状指没有面粉疙瘩且整体颜色均匀",
    "刚出锅的锡纸盘比较烫，请用夹子夹取或使用湿抹布之类的隔热材料拿取"
