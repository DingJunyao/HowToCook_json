  "steps": [
    {
      "step": 1,
      "content": "冬瓜去皮，切成约5cm长、3cm厚的片",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "将切好的冬瓜放入碗中，放入7.5g盐，将冬瓜抹匀，放置10分钟",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 3,
      "content": "换个碗放入肉末、葱姜末、2.5g盐、2.5g淀粉、胡椒粉、生抽",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "使用筷子在肉末中进行顺时针搅拌，搅拌到食材颜色没有明显对比（约2分钟）",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "将腌制好的冬瓜（会变软）使用清水洗三遍",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "拿出1片冬瓜片卷起来，并把肉塞进去",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 7,
      "content": "放入碟子中摆到碟子的边缘",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "打入0.5个鸡蛋到中间圆圈处",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "放入普通铁锅中水烧开后，蒸15分钟，盖上锅盖",
      "duration_minutes": 15,
      "tips": null
    },
    {
      "step": 10,
      "content": "开盖，取出蒸好的冬瓜酿肉",
      "duration_minutes": 1,
      "tips": "注意碟子很烫，小心操作"
    },
    {
      "step": 11,
      "content": "将冬瓜酿肉碟子的水倒入锅中，放入水淀粉（11.5g淀粉+25ml清水），加入25ml清水倒入锅中烧开",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 12,
      "content": "淋到冬瓜酿肉上",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "操作时，拿出冬瓜酿肉时注意碟子很烫，小心操作"
  ]
}