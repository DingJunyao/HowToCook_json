  "steps": [
    {
      "step": 1,
      "content": "牛肉洗干净切片。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "加入 15g 姜丝，1 个鸡蛋，15g 淀粉，8g 蚝油，10ml 料酒搅拌均匀，腌制 15 分钟。",
      "duration_minutes": 15,
      "tips": null
    },
    {
      "step": 3,
      "content": "香菜洗干净切好。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "锅里倒油，加入豆瓣酱，5g 姜丝，蒜片。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "倒入开水，煮成红汤。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "豆芽洗干净去掉尾须，放进开水里焯熟。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "将豆芽铺入碗底。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "将牛肉片一片一片的放进红汤中，煮熟以后捞出。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "将牛肉铺在豆芽上，撒上香菜梗。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 10,
      "content": "撒上香菜叶，辣椒粉，辣椒圈。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 11,
      "content": "另起锅烧热油，将热油淋在菜上面，就完成了。",
      "duration_minutes": null,
      "tips": null
    }
  ],
