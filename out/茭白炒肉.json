  "steps": [
    {
      "step": 1,
      "content": "茭白切片，每片厚度 0.5 cm",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "瘦肉切条，厚度 0.3-0.5 cm，加入料酒、生粉、盐、水搅拌腌制",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "姜切片、蒜头剁碎",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "起锅水烧开，放入茭白，水煮 60-90 S 后取出沥干",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "起锅，倒入 15 ml 油，倒入瘦肉，反复翻炒 60 S 取出",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "起锅，倒入 15 ml 油，倒入姜、蒜翻炒 30S，加入茭白继续翻炒 30 S",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "继续加入瘦肉翻炒 60 S，加入 20 ml 水，加入盐、鸡精后翻炒 60S 出锅",
      "duration_minutes": 2,
      "tips": null
    }
  ],
  "tips": [
    "最后一个步骤，可以考虑加蚝油、生抽代替盐上色"
  ]
}