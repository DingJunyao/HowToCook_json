  "steps": [
    {
      "step": 1,
      "content": "将排骨用冷水浸泡 10 分钟泡去血水，换水重复 2 次，用厨房纸吸干",
      "duration_minutes": 30,
      "tips": null
    },
    {
      "step": 2,
      "content": "将豆豉放入水中浸泡 5 分钟",
      "duration_minutes": 5,
      "tips": "浸泡后稍微剁碎会更入味"
    },
    {
      "step": 3,
      "content": "将所有食材混合（食用油放 3.3 ml），腌制 8-30 分钟",
      "duration_minutes": 20,
      "tips": "腌制时间越长越入味"
    },
    {
      "step": 4,
      "content": "水开后上锅蒸 18 分钟",
      "duration_minutes": 18,
      "tips": "蒸制时间随排骨大小调整，以筷子能轻松插入软骨处为准"
    },
    {
      "step": 5,
      "content": "焖 2 分钟",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "锅中倒入 3.3 ml 热油，加热到 180-200 ℃",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 7,
      "content": "均匀撒上葱花和白芝麻，热油浇在撒料上",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "传统的豉汁排骨不放撒料和淋热油",
    "吃剩的汤汁可以用来拌饭或者拌面"
  ]
}