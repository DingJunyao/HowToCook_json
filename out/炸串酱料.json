  "steps": [
    {
      "step": 1,
      "content": "所有原料在容器内混合，搅拌均匀。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "锅里烧热油，油的用量以在容器内没过所有原材料为佳。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "分三次淋入热油，每次 1/3，同时搅拌。",
      "duration_minutes": 3,
      "tips": "不得一次性倒入所有热油，必须分次倒入并搅拌。"
    },
    {
      "step": 4,
      "content": "最后放入香油 10ml，生抽 10ml，花椒油 10ml，蚝油 10ml。",
      "duration_minutes": 2,
      "tips": "调味可按自己喜好添加。"
    }
  ],
  "tips": [
