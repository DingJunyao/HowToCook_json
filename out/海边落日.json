  "steps": [
    {
      "step": 1,
      "content": "柠檬洗净，切出一片备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "选择一个容量在 350~400 毫升的透明玻璃杯",
      "duration_minutes": null,
      "tips": "透明玻璃杯能展现饮料的分层效果"
    },
    {
      "step": 3,
      "content": "放入大冰块，用搅拌棒搅拌冰杯",
      "duration_minutes": null,
      "tips": "冰杯可以提升饮品口感"
    },
    {
      "step": 4,
      "content": "加入红石榴糖浆",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "让橙汁沿搅拌棒导入酒杯，到杯中一半即可",
      "duration_minutes": null,
      "tips": "沿搅拌棒倒入可以避免破坏分层"
    },
    {
      "step": 6,
      "content": "轻轻搅拌半圈",
      "duration_minutes": null,
      "tips": "不要过度搅拌，保持分层效果"
    },
    {
      "step": 7,
      "content": "倒入苏打水",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "拿出调酒杯，加入白朗姆、蓝橙力娇酒、柠檬汁和冰块，然后用力摇晃",
      "duration_minutes": 1,
      "tips": "shake 的动作要充分"
    },
    {
      "step": 9,
      "content": "轻轻倒入酒杯中",
      "duration_minutes": null,
      "tips": "缓慢倒入可以保持美丽的渐变色效果"
    },
    {
      "step": 10,
      "content": "插上柠檬片和吸管",
      "duration_minutes": null,
      "tips": "柠檬片作为装饰，吸管用于饮用"
    }
  ],
  "tips": [
    "饮品有害健康，未成年人禁止饮酒",
