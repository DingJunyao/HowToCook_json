  "steps": [
    {
      "step": 1,
      "content": "五花肉切块，每块 2-3 cm 大小",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "锅中加入 150 ml 食用油，倒入五花肉，煎炸 2 分钟后，加入盐，翻炒五花肉，2 分钟后出锅",
      "duration_minutes": 4,
      "tips": "加盐的目的是锁住五花肉的油脂"
    },
    {
      "step": 3,
      "content": "锅中加入 50 ml 食用油，倒入白砂糖，翻炒到咖啡色",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "倒入五花肉，翻炒 30 秒，加入姜片、蒜头后翻炒 30 秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入料酒、五香粉、葱，加入水没过五花肉，盖上锅盖煮 10 分钟",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 6,
      "content": "加入生抽、老抽、蚝油，中火煮 20 分钟",
      "duration_minutes": 20,
      "tips": null
    },
    {
      "step": 7,
      "content": "开锅，大火烧汁，端盘",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "葱是整根，不需要切碎",
    "步骤二加盐的目的是锁住五花肉的油脂",
    "制作过程，用部分五花肉做了水煮处理，跟未处理的一起做后续制作，发现未水煮的肉质更Q弹"
  ]
