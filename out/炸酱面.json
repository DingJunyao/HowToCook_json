  "steps": [
    {
      "step": 1,
      "content": "菜码切丝备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "葱切碎。油锅烧热，下葱和肉，炒至肉完全熟透（无红色）",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "下豆瓣酱和甜面酱，继续炒至微微粘稠。盛出，得到炸酱",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 4,
      "content": "取大碗，加凉水备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "煮面条至断生（无白芯），盛入第 4 步装有凉水的碗中",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 6,
      "content": "立即控水捞出，盛入干净的碗中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "取第 3 步炸酱，倒入碗中，拌匀。然后取第 1 步菜码，倒入碗中，拌匀",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
