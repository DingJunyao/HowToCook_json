  "steps": [
    {
      "step": 1,
      "content": "大蒜和生姜切碎，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "小米辣切成辣椒圈，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "五花肉切成肉糜（本来就是买的肉糜的跳过）",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "肉糜中加入一半的食盐和味极鲜酱油，搅拌均匀，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "鸭蛋用菜刀竖着对半切开（注意安全），去除蛋黄（一定要去除，不然会腥），剩下的蛋白捣碎成大约 2 mm * 2 mm 大小，不用太碎，备用",
      "duration_minutes": 3,
      "tips": "一定要去除蛋黄，不然会腥"
    },
    {
      "step": 6,
      "content": "打开豆腐包装，用水果刀将在盒子中的豆腐划成大约 2.5 cm * 3 cm 大小，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 7,
      "content": "热锅，锅内放入 10ml - 15ml 食用油。等待 10 秒让油温升高",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "调成小火，放入大蒜、生姜、辣椒圈、花椒、咸鸭蛋、蒜蓉辣酱翻炒 20 秒，炒出香味",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "调成中火，放入肉糜，翻炒大约 1 分钟，肉炒变色",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "调成小火，放入豆腐，将剩下的食盐、味极鲜酱油均匀的洒在豆腐上",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 11,
      "content": "从锅边倒入开水（不然豆腐容易破），没过豆腐即可",
      "duration_minutes": 1,
      "tips": "从锅边倒入，不然豆腐容易破"
    },
    {
      "step": 12,
      "content": "开大火，水沸腾后立马转入中火，等待大约 10 分钟",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 13,
      "content": "等到水只剩 1/5 并且豆腐表面已经入色，关火，盛盘",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "期间一定要注意观察，防止糊锅"
  ]
}