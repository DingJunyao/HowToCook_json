  "steps": [
    {
      "step": 1,
      "content": "葱切花，蒜切沫，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "生抽、老抽、蚝油、盐混合调料汁，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "小米椒切圈，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "豆角去筋，45° 斜切 4-10cm 小段，备用",
      "duration_minutes": 3,
      "tips": "切豆角需要一定的刀工，不会的可以使用剪刀"
    },
    {
      "step": 5,
      "content": "起锅烧油 5-7.5ml，冒烟后放入葱、小米椒，翻炒至闻到香味",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "加入豆角，翻炒 30s",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "加入料汁，开大火翻炒 2 分钟",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 8,
      "content": "倒入 75ml 水，转中小火，盖上锅盖焖制 8-10 分钟",
      "duration_minutes": 9,
      "tips": null
    },
    {
      "step": 9,
      "content": "加入蒜沫，出锅",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "切豆角需要一定的刀工，不会的可以使用剪刀"
