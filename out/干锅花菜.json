  "steps": [
    {
      "step": 1,
      "content": "花菜朵朝下，没入淡盐水中浸泡 20 分钟。然后洗净用小刀拆成小朵",
      "duration_minutes": 20,
      "tips": null
    },
    {
      "step": 2,
      "content": "入开水锅中焯水 1 分钟，捞出立即用冷水冲淋至完全凉透，沥水备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "五花肉切成薄片，大蒜白色切下用刀背拍扁，小红辣椒切成段",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "锅烧热放油，油热下大葱白爆香",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "下五花肉片入锅，用中火煸炒至表面全部变色，继续煸炒一会儿，把肥肉部分的油份逼出一部分",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "倒入红辣椒段和花菜，翻炒几下",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "加入 10 ml 生抽",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "再加入 5 g 白糖，转大火不断翻炒 1 分钟",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "把大蒜叶部分切成段，放入锅中，翻炒几下后，关火盖上盖子焖 1 分钟即可",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": []
