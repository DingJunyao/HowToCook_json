  "steps": [
    {
      "step": 1,
      "content": "准备材料：准备快煮燕麦 40g、牛奶 280ml、鸡蛋 1 个、底油少量（可选椒盐 3g）",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "将燕麦放入容器中，倒入牛奶并搅拌",
      "duration_minutes": 1,
      "tips": "确保燕麦完全浸泡在牛奶中"
    },
    {
      "step": 3,
      "content": "将混合物放入微波炉，中等火力微波 4 分钟",
      "duration_minutes": 4,
      "tips": "不建议混合物超过容器容量 50%，否则加热过程中内容物极有可能溢出"
    },
    {
      "step": 4,
      "content": "热锅，锅内放一层底油，油热后煎鸡蛋，每面煎 20 秒，关火装盘",
      "duration_minutes": 2,
      "tips": "可考虑调底味，添加 3g 椒盐（可选）"
    },
    {
      "step": 5,
      "content": "将煎好的鸡蛋搭配牛奶燕麦一起食用",
      "duration_minutes": 1,
      "tips": "水果蔬菜、苏打饼干搭配食用更佳"
    }
  ],
  "tips": [
    "不建议混合物超过容器容量 50%，否则加热过程中内容物极有可能溢出",
