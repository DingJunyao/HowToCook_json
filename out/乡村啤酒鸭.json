  "steps": [
    {
      "step": 1,
      "content": "鸭肉焯水以去腥去血水：鸭肉清洗一遍放进锅中，加清水淹没鸭肉，加 20 ml 料酒，加备用的 1 根大葱，加生姜（拍散的 2 厘米），开火烧滚，捞出浮沫，鸭肉捞出，清水洗干净备用",
      "duration_minutes": 5,
      "tips": "注意观察浮沫，及时撇去"
    },
    {
      "step": 2,
      "content": "锅清洗干净烧热，加 60 ml 的花生油",
      "duration_minutes": 1,
      "tips": "油温不宜过高，避免糊锅"
    },
    {
      "step": 3,
      "content": "油温到 60 度的时候，加一把花椒（30 颗）",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "加鸭肉翻炒 4 分钟，2 分钟后加入所有的香料，3 分钟的时候加入所有的料头（生姜、大蒜、小米辣）",
      "duration_minutes": 4,
      "tips": "持续翻炒，避免粘锅"
    },
    {
      "step": 5,
      "content": "加入 1000 ml 的啤酒，开始烧鸭肉",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "烧鸭肉 30 分钟，10 分钟的时候加盐（3 克）、生抽（10 ml）、老抽（5 ml），20 分钟加入所有的辅料（青椒和红椒段），29 分钟加入蒜苗段和大葱段",
      "duration_minutes": 30,
      "tips": "注意观察沸腾的水位线，如发现低于 2/3 的食材应加热水或者加啤酒"
    },
    {
      "step": 7,
      "content": "最后翻炒 1 分钟，出锅",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "操作时，需要注意观察沸腾的水位线，如发现低于 2/3 的食材应加热水或者加啤酒"
  ]
