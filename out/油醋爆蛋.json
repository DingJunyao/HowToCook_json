  "steps": [
    {
      "step": 1,
      "content": "鸡蛋不需打散，直接打入碗中备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "香葱切 3cm 长小段即可",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "蒜瓣和小米辣放入打蒜器，打成沫",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "将香醋、生抽、蚝油、白糖、水加入小碗，搅拌均匀作为糖醋料汁",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "油热倒入鸡蛋，等鸡蛋凝固之后铲成大块，倒入蒜沫、小米辣沫、倒入糖醋料汁",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "大火收汁、快出锅时加入葱段即可",
      "duration_minutes": 2,
      "tips": null
    }
  ],
  "tips": [
    "老恒和酿造香醋零添加口味最好，醋香是本菜灵魂所在"
  ]
