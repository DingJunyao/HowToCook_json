      "is_estimated": true
    },
    {
      "ingredient_name": "食用油",
      "quantity": 150,
      "unit": "ml",
      "quantity_range": {
        "min": 100,
        "max": 150
      },
      "is_optional": false,
      "note": "炸制土豆用，土豆能浮在油上面即可",
      "original_quantity": "适量",
      "is_estimated": true
    },
    {
      "ingredient_name": "淀粉",
      "quantity": 15,
      "unit": "g",
      "quantity_range": null,
      "is_optional": false,
