  "steps": [
    {
      "step": 1,
      "content": "白蘑菇切片备用，洋葱切末备用。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "平底锅中放入黄油，小火融化后加入洋葱炒至透明。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "加入白蘑菇翻炒至出水变软，撒入面粉搅拌均匀。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入牛奶和清水，搅拌均匀后小火煮沸，保持搅拌防止糊底。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "转小火煮约 10 分钟，汤汁浓稠。",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 6,
      "content": "倒入淡奶油继续加热 1 分钟，加入盐和黑胡椒调味。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "熄火后可用料理机打成细腻浓汤（可选）。",
      "duration_minutes": null,
      "tips": "此步骤为可选操作，使用料理机可以制作更细腻的浓汤口感"
    }
  ],
  "tips": [
    "可将部分蘑菇预留作为装饰，提前煎香再添加。",
    "使用鸡高汤代替清水风味更佳，建议控制总液体不超过 300 毫升/份。",
    "喜欢浓汤口感可适当增加面粉和淡奶油用量。",
    "建议现做现吃，不建议冷藏或冷冻保存。"
  ]
}