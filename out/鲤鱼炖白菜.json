  "steps": [
    {
      "step": 1,
      "content": "鲤鱼清洗干净，改刀（在鱼身上多划几个伤口，方便入味）",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "娃娃菜清洗干净放入盘中备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "锅中加油，等油热放入盐、姜、蒜、郫县豆瓣酱、桂皮、八角炒出香味",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "把鱼放锅里煎，每 30 秒需要翻面一次，共煎 3 分钟",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入水（水量尽量和鱼平齐，可以少一点点），放入生抽、老抽、娃娃菜",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "大火炖 15-20 分钟，汤汁快干时添加盐即可出锅",
      "duration_minutes": 18,
      "tips": null
    }
  ],
  "tips": [
    "也可以放一些粉条，粉条先用凉水/热水泡软，可以和娃娃菜一起放入"
  ]
}