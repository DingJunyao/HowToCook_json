  "steps": [
    {
      "step": 1,
      "content": "将小葱洗净，切成长段（约 5-7 cm）。葱白和葱绿可以分开。",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "锅中加入食用油，中火烧热。先放入葱白段，煸炒至微黄。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "加入葱绿段，转小火，继续煸炒。保持小火，耐心煸炒约 15-20 分钟，直至葱段变得焦黄酥脆。",
      "duration_minutes": 20,
      "tips": "炸葱油时，火一定要小，要有耐心，才能将葱的香味充分炸出"
    },
    {
      "step": 4,
      "content": "将焦黄的葱段捞出，葱油保留在锅中。在锅中的葱油中，加入生抽、老抽、白糖。小火加热并搅拌，约 1 分钟，至糖溶解，酱汁混合均匀。立即关火。将制作好的葱油酱汁倒入容器中，放凉后密封保存。",
      "duration_minutes": 2,
      "tips": "制作好的葱油酱汁可以冷藏保存一段时间，下次吃面时直接取用"
    },
    {
      "step": 5,
      "content": "锅中加入饮用水，大火烧开。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "放入干面条，根据面条包装说明，煮至熟透（通常 3-8 分钟，以包装说明为准）。",
      "duration_minutes": 6,
      "tips": null
    },
    {
      "step": 7,
      "content": "将煮好的面条捞出，沥干水分，放入碗中。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "在装有面条的碗中，加入之前做好的葱油酱汁。可以加入之前炸好的葱段（可选）。用筷子快速搅拌均匀，即可食用。",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "炸葱油时，火一定要小，要有耐心，才能将葱的香味充分炸出",
    "制作好的葱油酱汁可以冷藏保存一段时间，下次吃面时直接取用"
  ]
}