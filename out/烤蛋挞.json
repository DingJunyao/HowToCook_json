  "steps": [
    {
      "step": 1,
      "content": "称量15克淡奶油",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "加入2.67克白砂糖（甜度中等，可按个人口味增减，建议范围0.67-1.11克）",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "加入6.67克牛奶",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "取0.27个蛋黄加入",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "均匀搅拌所有材料直至白砂糖全部融化",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "使用网筛对搅拌完成的食材进行过滤，滤除鸡蛋黏膜、鸡蛋壳、未融化的白砂糖、结块的淡奶油",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 7,
      "content": "将蛋挞皮以0.5厘米的间隔均匀放置于烤盘中",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "将过滤完成的食材倒入蛋挞皮中，液面距离蛋挞皮上沿0.5厘米即可，不宜过多",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "将烤箱预热至220摄氏度（约10分钟）",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 10,
      "content": "将蛋挞放入烤箱中进行烤制，温度为200摄氏度，时间为25分钟",
      "duration_minutes": 25,
      "tips": null
    },
    {
      "step": 11,
      "content": "烤制结束后即可食用",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "操作时请务必小心烤箱高温，防止烫伤"
