  "steps": [
    {
      "step": 1,
      "content": "洋葱切片，猪肉切片，蒜头拍碎，混合调味料备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "炒锅内倒入 1 大匙食用油（等待 10 秒让油温升高），倒入猪肉",
      "duration_minutes": 1,
      "tips": "等待油温升高再下肉"
    },
    {
      "step": 3,
      "content": "炒至变色后下蒜头炒香盛起备用",
      "duration_minutes": 2,
      "tips": "猪肉变色后即可下蒜头"
    },
    {
      "step": 4,
      "content": "原锅下洋葱翻炒 3~4 分钟后加入调味料炒匀",
      "duration_minutes": 4,
      "tips": "洋葱需要炒软炒透"
    },
    {
      "step": 5,
      "content": "下刚盛起备用的猪肉翻炒至猪肉熟后",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "待猪肉熟后再翻炒 1、2 分钟即可起锅",
      "duration_minutes": 2,
      "tips": null
    }
  ],
  "tips": [
    "猪肉可选猪肩肉片或是切好的肉丝看个人喜好"
  ]
