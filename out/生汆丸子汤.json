  "steps": [
    {
      "step": 1,
      "content": "肉改刀切开，肥瘦三七分，上刀剁一剁，用刀背砸一砸，把肉筋打开打松疏，反复剁成肉末",
      "duration_minutes": 5,
      "tips": "要想好吃得自己剁，机器打的太黏糊了"
    },
    {
      "step": 2,
      "content": "每斤肉，6克盐，1克胡椒粉，上手抓匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "葱姜花椒水分次加，边加边搅，用手揉匀，让肉吸饱水。每斤肉末80克葱姜花椒水",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "放入鸡蛋清，继续顺着一个方向搅",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入40克土豆淀粉，搅匀",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "加入熟豆油，这是为了保持其嫩滑弹的状态",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "起锅烧水，烧开，改小火，似开非开的样子",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 8,
      "content": "上手挤丸子入锅，全部漂起来后用小火煮1分钟",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 9,
      "content": "粉丝放碗底，加木耳、黄花、小香葱并用盐、胡椒粉、鸡粉打底调味",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "连汤带丸子冲入碗中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 11,
      "content": "淋3-5滴香油",
      "duration_minutes": 0,
      "tips": null
    },
    {
      "step": 12,
      "content": "加一小颗香菜",
      "duration_minutes": 0,
      "tips": null
    }
  ],
  "tips": [
    "要想好吃得自己剁肉，机器打的太黏糊了",
    "辣椒油可以根据口味放"
  ]
}