  "steps": [
    {
      "step": 1,
      "content": "菠菜去根，洗净，放在篮子里，焯水",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "将鸡蛋打入碗中，搅匀",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "热锅，加入 10ml 油",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "油热后，倒入鸡蛋液，中火翻炒 15 秒，先煎成蛋饼，然后再用锅铲切成小块",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "关火，将鸡蛋块盛到盘子中，不要洗锅",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "重新开火，倒入 5ml 油，油热后，放入菠菜，大火翻炒 15 秒后，倒入鸡蛋块，翻炒均匀",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "加入 5g 盐、100ml 饮用水，大火翻炒 10 秒",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "关火，盛盘",
      "duration_minutes": null,
      "tips": null
    }
