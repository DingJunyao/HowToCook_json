  "steps": [
    {
      "step": 1,
      "content": "西红柿切成小丁、鸡蛋打入碗中搅拌、豆腐切块备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "起锅烧油，放入姜片 5 秒后倒入西红柿翻炒 30 秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "锅中加入开水，汤水烧开，60 秒后倒入鸡蛋液、豆腐块",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "汤水重新烧开后，加入水淀粉，沿一个方向搅拌 2 圈",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入鸡精、盐、香葱，30 秒后起锅",
