  "steps": [
    {
      "step": 1,
      "content": "胡萝卜、包菜切丝备用",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "粉丝先用冷水浸泡1小时，然后将粉丝放入锅中，加入开水烧至粉丝烫软捞出备用",
      "duration_minutes": 60,
      "tips": "需提前1小时浸泡粉丝"
    },
    {
      "step": 3,
      "content": "鸡蛋打入碗中，加入盐后搅拌15秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "葱、蒜、辣椒切成小粒备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "起锅烧油，倒入鸡蛋，打散炒熟盛出",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "再倒入油，放入葱、蒜、干辣椒翻炒8秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "下胡萝卜、包菜丝儿翻炒30秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "放入粉丝",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "放调料，生抽15ml，老抽10ml，蚝油10ml，盐2克",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "放入之前炒好的鸡蛋，翻炒约15秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 11,
      "content": "出锅摆盘",
      "duration_minutes": 1,
      "tips": null
    }
  ],
