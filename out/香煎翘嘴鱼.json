  "steps": [
    {
      "step": 1,
      "content": "鱼开背杀好（让卖鱼的杀好，千万不要剖腹杀鱼，切记是开背），清洗干净",
      "duration_minutes": 5,
      "tips": "切记鱼是开背杀"
    },
    {
      "step": 2,
      "content": "鱼表面用盐涂抹均匀，倒入料酒约 27ml（一人份），姜末 7g，放入冰箱保鲜层进行腌制 1-2 天",
      "duration_minutes": 10,
      "tips": "腌制时，鱼表面涂抹均匀食盐即可"
    },
    {
      "step": 3,
      "content": "取出腌制好的鱼，用绳挂起晾晒至半干（约 1-2 天，具体时间需结合气温与阳光）",
      "duration_minutes": 5,
      "tips": "晾晒时间 1-2 天即可"
    },
    {
      "step": 4,
      "content": "食用前请将鱼用清水清洗，沥干水分（防止水遇油飞溅）",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 5,
      "content": "开大火将锅烧热，迅速改小火，锅中放油，尽量保持整个锅表面有油，将鱼沿锅边划入锅内（先煎鱼背面）",
      "duration_minutes": 2,
      "tips": "煎鱼全程小火"
    },
    {
      "step": 6,
      "content": "鱼入锅后（和翻面后），不要着急移动鱼的位置（此时容易破皮），煎约 30 秒后，尝试晃动锅",
      "duration_minutes": 1,
      "tips": "刚入锅时不要移动鱼，会破皮"
    },
    {
      "step": 7,
      "content": "背面煎约 1 分钟后，翻面煎约 1-2 分钟，煎至两面金黄",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 8,
      "content": "等两面都煎好时，把鱼推向锅边一点，留点空间放入豆瓣酱炒香味，放入姜蒜",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "炒出佐料香味后，加入料酒，生抽，老抽，倒入热水，水量和鱼平齐或者少点",
      "duration_minutes": 2,
      "tips": "注意豆瓣酱，白糖的调鲜效果，与陈醋的增香效果"
    },
    {
      "step": 10,
      "content": "此时改中大火，煮 5-10 分钟，后放入青椒断，白糖，鸡精，十三香，陈醋",
      "duration_minutes": 8,
      "tips": "青椒断放入后注意观察熟透程度，里面的青椒很好吃"
    },
    {
      "step": 11,
      "content": "改小火 2-5 分钟，放入葱，香菜，即可出锅",
      "duration_minutes": 3,
      "tips": "注意火候的切换，香菜最后放"
    }
  ],
  "tips": [
    "切记鱼是开背杀，腌制时，鱼表面涂抹均匀食盐即可，腌制时间，晾晒时间 1-2 天即可",
    "煎鱼全程小火，刚入锅时不要移动鱼，会破皮",
    "青椒断放入后注意观察熟透程度，里面的青椒很好吃，另外香菜最后放",
    "注意火候的切换，豆瓣酱，白糖的调鲜效果，与陈醋的增香效果"
  ]
}