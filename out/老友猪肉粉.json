  "steps": [
    {
      "step": 1,
      "content": "全部猪肉用料酒、盐、生抽、生粉、胡椒粉倒在一个碗里调味，备用",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "热锅不放油，下全部酸笋把水份炒干，炒干的酸笋中间留点空间",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "放入10ml-15ml食用油与全部大蒜、剁椒、豆豉到炒干的酸笋中间，全部推到中间炒出香味",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "放入全部调味好的猪肉，持续放入10ml生抽炒一分钟",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "放入5ml米醋、10ml生抽、450ml清水一起煮开",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "水煮开后，放入温水泡好的米粉，继续煮3分钟就可以盛盘",
      "duration_minutes": 3,
      "tips": null
    }
  ],
  "tips": [
    "记得米粉必须是泡过的才好吃，没有泡过的话是很难吃的！"
  ]
