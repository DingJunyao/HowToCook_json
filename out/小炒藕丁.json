  "steps": [
    {
      "step": 1,
      "content": "大葱、小米辣切小段，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "莲藕去皮，切成不超过 3cm 的小块，放入水中备用（防止氧化发黑）",
      "duration_minutes": 3,
      "tips": "放入水中可防止氧化发黑"
    },
    {
      "step": 3,
      "content": "取炒锅，锅内放入 250ml 凉水，煮沸",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "将藕丁下入沸水中，焯水 2 分钟后，取出放入盘中备用",
      "duration_minutes": 2,
      "tips": "焯水2分钟"
    },
    {
      "step": 5,
      "content": "将锅中水倒掉后，将锅加热干燥，加入 5-7.5 ml 食用油",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "待油温升高后，下入葱花，小米辣爆香",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "将处理好的藕丁下入锅中，大火翻炒",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入生抽、老抽、耗油",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "翻炒 2 分钟即可出锅",
      "duration_minutes": 2,
      "tips": null
    }
  ],
  "tips": [
    "食用莲藕要挑选外皮呈黄褐色、肉肥厚而白的",
    "如果发黑，有异味，则不宜食用",
    "请尽量不要使用铁器，会导致莲藕发黑"
  ]
}