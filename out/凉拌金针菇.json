  "steps": [
    {
      "step": 1,
      "content": "将金针菇根部切除，用清水冲洗干净，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "将小葱洗净，切成葱花，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "将大蒜去皮，切成蒜末，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "锅中加入 1000 ml 饮用水，大火烧开",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "放入金针菇，煮 1-2 分钟，至金针菇变软",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "将煮好的金针菇捞出，沥干水分，放入一个较大的碗中，备用",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "在另一个干净的小碗中，加入 15 ml 生抽，10 ml 醋，3 g 白糖（可选），5 ml 香油（可选）",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入切好的大蒜末",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "搅拌均匀，使白糖充分溶解，酱汁混合均匀",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "将制作好的酱汁均匀淋在金针菇上",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 11,
      "content": "撒上切好的小葱花",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 12,
      "content": "根据个人喜好，淋上 5 ml 辣椒油（可选）",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 13,
      "content": "用筷子轻轻拌匀，即可食用",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "金针菇焯水时间不宜过长，以免影响口感",
    "酱汁的比例可以根据个人口味喜好进行调整",
    "如果不喜欢吃辣，可以省略辣椒油"
  ]
}