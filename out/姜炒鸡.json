  "steps": [
    {
      "step": 1,
      "content": "鸡尽量剁成 1cm 的小块，洗净后滤干，再放生抽腌和料酒腌制 30 分钟",
      "duration_minutes": 30,
      "tips": "腌制时间充足可更好入味"
    },
    {
      "step": 2,
      "content": "先热锅到微微冒烟，放入食用油，等 5 秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "下入姜片后转中火炒 30 秒",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 4,
      "content": "下入鸡块翻炒 3 分钟，炒干水分，炒出鸡油",
      "duration_minutes": 3,
      "tips": "要耐心炒出鸡油，这样更香"
    },
    {
      "step": 5,
      "content": "放入各种剁碎的辣椒和大蒜子，加盐和老抽继续翻炒 30 秒",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 6,
      "content": "倒入啤酒，中小火焖 2 分钟",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 7,
      "content": "大火收汁盛盘",
      "duration_minutes": 3,
      "tips": "大火收汁可以让菜品更有光泽"
    }
  ],
  "tips": [
    "湖南口味菜，下饭五颗星",
    "食材平平无奇又十分容易烹制，一学就会"
  ]
}