  "steps": [
    {
      "step": 1,
      "content": "猪肉去皮，切成 2 cm * 6 cm * 0.5 cm 薄片备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "芹菜去叶，去掉根部 2cm，然后从中对半切开，切成 2cm 段备用",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "大蒜去皮切粒备用，葱切 0.2cm 薄片备用，姜切细丝备用",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "炒锅烧热至冒烟后，倒入 3ml 食用油滑锅后倒出底油",
      "duration_minutes": 1,
      "tips": "加热至冒烟是为了让锅充分受热"
    },
    {
      "step": 5,
      "content": "重新加入食用油，加入肉片、葱姜蒜、干红椒，炒 1 分钟，注意不停匀速翻炒",
      "duration_minutes": 1,
      "tips": "不停匀速翻炒防止粘锅和糊锅"
    },
    {
      "step": 6,
      "content": "加入料酒、生抽、老抽，再翻炒 1 分钟",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "续入 500ml 热水。盖上锅盖炖煮 3 分钟",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 8,
      "content": "将芹菜、青椒倒入锅中，加入盐、五香粉调味，盖上锅盖继续炖煮 3 分钟后关火",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 9,
      "content": "蒸锅加入 1000ml 水，烧开上汽后，将面条摊平在笼屉上放入锅中，蒸 15 分钟",
      "duration_minutes": 20,
      "tips": "面条要摊平，尽量散开，避免蒸熟后团在一起"
    },
    {
      "step": 10,
      "content": "面条蒸熟后取出，用筷子和无情铁手扒拉散开在案板上，室温冷却",
      "duration_minutes": 5,
      "tips": "取出蒸好的面条时尽量动作轻一些，避免蒸屉翻到面条触水"
    },
    {
      "step": 11,
      "content": "将面条放入菜锅中搅拌，搅拌方式为一手持筷，一手持锅铲将菜翻至面条上面，以面条全部均匀上色为搅拌完成标准",
      "duration_minutes": 3,
      "tips": "面条太长时可以拽断，方便后续搅拌与盛取"
    },
    {
      "step": 12,
      "content": "将搅拌后的面条再次放在笼屉上，再次蒸 10 分钟关火",
      "duration_minutes": 10,
      "tips": "两次蒸面条时，都要尽量弄散开，可以避免蒸好后团在一起"
    }
  ],
  "tips": [
    "切割猪肉时，可以让菜市场摊贩帮忙，根据经验，请求时机把握在已切割后未付款之前成功率最高",
    "首次做饭时可以提前备好料防止手忙脚乱，后续熟练后可以并发执行",
    "两次蒸面条时，都要尽量弄散开，可以避免蒸好后团在一起。面条太长时可以拽断，方便后续搅拌与盛取",
    "取出蒸好的面条时尽量动作轻一些，避免蒸屉翻到面条触水",
    "佐餐时啤酒更配呦"
  ]
}