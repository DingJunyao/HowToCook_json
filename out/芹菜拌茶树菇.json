  "steps": [
    {
      "step": 1,
      "content": "用热水壶烧一壶热水，备用（如果是芹菜苗这一步略过）",
      "duration_minutes": 3,
      "tips": "如果是芹菜苗此步骤略过"
    },
    {
      "step": 2,
      "content": "新鲜的芹菜苗或者芹菜摘去黄叶清洗，备用",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "将芹菜摘去叶子单独放一个盆中，将芹菜茎用刀划成 2-3 毫米宽的芹菜条备用（如果是芹菜苗这一步略过）",
      "duration_minutes": 5,
      "tips": "这一步的目的是让芹菜断生的更快更均匀，吃起来更脆更爽口"
    },
    {
      "step": 4,
      "content": "芹菜苗切成 4cm 的芹菜段，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "起锅开火，将热水壶的开水倒入锅中待水起泡沸腾（如果是芹菜苗这一步略过）",
      "duration_minutes": 2,
      "tips": "如果是芹菜苗此步骤略过"
    },
    {
      "step": 6,
      "content": "将切好的芹菜条放入锅中焯水，大约 20 秒放入芹菜叶，5 秒后关火全部捞出过凉水，备用（如果是芹菜苗这一步略过）",
      "duration_minutes": 1,
      "tips": "焯水时的水位需要没过芹菜；如果是芹菜苗此步骤略过"
    },
    {
      "step": 7,
      "content": "将盆中焯好的芹菜或者芹菜苗撒上准备好的食盐、香油、耗油和味极鲜搅拌均匀",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "将茶树菇倒入盆中搅拌均匀",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "装盘",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "开吃",
      "duration_minutes": 0,
      "tips": null
    }
  ],
  "tips": [
    "焯水时的水位需要没过芹菜",
    "芹菜叶太老太硬的话可以不要"
  ]
}