  "steps": [
    {
      "step": 1,
      "content": "土豆洗净、去皮。茄子、尖椒洗净。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "葱切0.5cm小段。蒜剁碎。姜切沫。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "茄子、土豆、尖椒均切成约15g的小块。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "热锅，加入油。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入土豆，煎炸大约3分钟，待其到大约8分熟，以显示金黄色为准。",
      "duration_minutes": 3,
      "tips": "煎炸至金黄色"
    },
    {
      "step": 6,
      "content": "捞出土豆，留下油。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 7,
      "content": "加入茄子，煎炸大约40秒，待其到大约7分熟，以显示金黄色为准。",
      "duration_minutes": 1,
      "tips": "煎炸至金黄色"
    },
    {
      "step": 8,
      "content": "如果锅内已经没有流动的油，可以考虑补充油。",
      "duration_minutes": 0.5,
      "tips": "根据实际情况补充油"
    },
    {
      "step": 9,
      "content": "放入葱。放入姜。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 10,
      "content": "放入豆瓣酱。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 11,
      "content": "放入生抽。放入盐。放入糖。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 12,
      "content": "放入之前处理的土豆。放入尖椒。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 13,
      "content": "翻炒1分钟。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 14,
      "content": "放入蒜。加入水和淀粉。",
      "duration_minutes": 0.5,
      "tips": null
    },
    {
      "step": 15,
      "content": "待水开后，汤减少一半时，关火盛盘。",
      "duration_minutes": 3,
      "tips": "汤减半即可关火"
    }
  ],
  "tips": [
    "土豆煎炸至金黄色，约8分熟",
    "茄子煎炸至金黄色，约7分熟",
    "注意根据实际情况补充油",
    "汤汁减半即可关火"
  ]
}