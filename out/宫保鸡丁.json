  "steps": [
    {
      "step": 1,
      "content": "手枪腿用剪刀去骨，鸡肉面用刀背拍打一遍，切条后切至 1.5cm 见方肉丁；泡于清水 10 分钟，捞出控干备用（若是鸡胸脯肉，则可以直接进行切丁以及之后的动作）",
      "duration_minutes": 15,
      "tips": "鸡胸脯肉可以跳过去骨拍打步骤"
    },
    {
      "step": 2,
      "content": "取大葱葱绿与姜片 5g 于碗中，倒入 50g 开水备用；葱白切 1.5cm 圆粒备用；取花生放入微波炉高火 5 分钟焙干备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "鸡丁中加入盐 2g，老抽酱油 5g，料酒 15g，淀粉 15g 搅拌均匀，至微微发干；缓慢加入部分葱姜水，搅拌鸡丁至粘手；保鲜膜密封，放入冰箱腌制 1 小时",
      "duration_minutes": 60,
      "tips": "腌制时间可以根据实际情况调整"
    },
    {
      "step": 4,
      "content": "干辣椒切段；起锅，大火烧热转小火；放入干辣椒焙干至微微发糊，捞起备用；花椒焙干至有香味，捞起备用",
      "duration_minutes": 5,
      "tips": "焙干辣椒和花椒时要用小火，避免糊掉"
    },
    {
      "step": 5,
      "content": "转大火，倒入 20g 植物油，7 成热（竹筷子起泡）下入鸡丁，煎至上面开始发白，用锅铲翻面，煎 30s 后翻炒均匀",
      "duration_minutes": 3,
      "tips": "7成热判断标准是竹筷子插入油中会起泡"
    },
    {
      "step": 6,
      "content": "下入葱粒翻炒，加入余下葱姜水不够 100g 再加一点清水（务必是热水）；盖上锅盖，转中小火焖 2 分钟",
      "duration_minutes": 2,
      "tips": "加水时务必是热水"
    },
    {
      "step": 7,
      "content": "转大火，下入熟花生，干辣椒和花椒；加入鸡精 2g，香醋 5g，白糖 2g，翻炒均匀",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "淀粉 10g 加 50g 清水调成水淀粉，加入锅中，翻炒均匀，收汁到自己想要的浓度",
      "duration_minutes": 2,
      "tips": "水淀粉可以分次加入，避免过稠"
    },
    {
      "step": 9,
      "content": "关火，淋入芝麻油 10g，即可出锅",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "辣椒依据个人口味酌量添加，怕辣可去籽",
    "此菜谱为一至两人份，多人只需简单加倍即可"
  ]
}