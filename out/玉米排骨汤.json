  "steps": [
    {
      "step": 1,
      "content": "大葱切成 3-4cm 的大段，用刀背拍一下",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "玉米剁成小块",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "胡萝卜切成滚刀块",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "生姜去皮切大片",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "新鲜的排骨砍成小块",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "排骨凉水下锅，放入大葱、生姜、料酒开始焯水，大火烧开，撇去浮沫，捞出排骨，沥干水分",
      "duration_minutes": 8,
      "tips": "焯水可以去腥去血沫"
    },
    {
      "step": 7,
      "content": "热锅凉油，切大片的生姜和排骨一起下锅煸炒，待排骨表面微微焦黄，放入醋，继续煸炒一分钟",
      "duration_minutes": 5,
      "tips": "醋可加速肉质软烂"
    },
    {
      "step": 8,
      "content": "冲入开水，一次给足，之后就不要再加了，大火烧开",
      "duration_minutes": 3,
      "tips": "一定要用开水，一次加足"
    },
    {
      "step": 9,
      "content": "先下入玉米，放入胡椒粉，盖盖小火炖二十分钟",
      "duration_minutes": 20,
      "tips": null
    },
    {
      "step": 10,
      "content": "放入胡萝卜，盖盖继续小火炖四十分钟",
      "duration_minutes": 40,
      "tips": null
    },
    {
      "step": 11,
      "content": "出锅前三分钟，加盐调味，最后撒上一把小葱花即可",
      "duration_minutes": 3,
      "tips": "根据最后汤剩余的量调整盐的用量"
    }
  ],
  "tips": [
    "这道菜制作起来并不难，而且食材简单，对新手友好",
    "适合降温的时候来上一大碗",
    "焯水可以去腥去血沫",
    "醋可加速肉质软烂",
    "一定要用开水，一次加足，之后不要再加水"
  ]
}