  "steps": [
    {
      "step": 1,
      "content": "锅中加水，烧开后放入意面",
      "duration_minutes": 9,
      "tips": "等待 6-12 分钟，注意意面盒子上标注的时间"
    },
    {
      "step": 2,
      "content": "洋葱切成小丁",
      "duration_minutes": 3,
      "tips": "在烧水的时候进行，但请注意煮面的时间"
    },
    {
      "step": 3,
      "content": "空锅中倒油，中火下入洋葱碎",
      "duration_minutes": 4,
      "tips": "时刻搅拌，注意不要让洋葱烧糊，直到洋葱变成半透明状"
    },
    {
      "step": 4,
      "content": "下入肉沫，继续搅拌（搅散），直到肉末变成棕色",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入意大利面酱，稍微搅拌一下即可",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "把煮好的意大利面沥干水分并倒入肉酱中搅拌均匀即可（或者直接把做好的肉酱倒在意面上也行）",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "意大利面分为很多不同的粗细，煮面条之前请注意意面盒子上标注的时间",
    "意大利面酱并不是番茄酱，平常用的番茄酱准确是叫番茄沙司，而意大利面酱虽然和番茄沙司都是调味过的番茄酱，但加的调味料不同"
  ]
}