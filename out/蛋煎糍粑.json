  "steps": [
    {
      "step": 1,
      "content": "把糍粑切成长方形小块，便于后面煎",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "碗里打入一个鸡蛋并把鸡蛋搅碎，加入 2g 食用盐",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "将切好的小糍粑依次放入搅碎的鸡蛋里面，涂抹完糍粑双面为止",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "锅里倒入植物油 10ml，把涂抹好的糍粑小块放进去小火慢慢煎软",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 5,
      "content": "将剩下的鸡蛋液慢慢倒在糍粑表面",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "用筷子或者勺子为糍粑翻面，来回煎至金黄色后开吃",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "放糍粑进去时候注意把糍粑间隔开来，防止粘在一起",
    "鸡蛋的量根据糍粑的量而定",
    "糖的量根据个人喜好"
  ]
}