  "steps": [
    {
      "step": 1,
      "content": "起锅烧热水，放入排骨、姜片、料酒，煮开后用勺子舀去白色油沫，2-3分钟后出锅",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "冷水清洗排骨，清洗2-3遍",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "小火起锅，加入食用油，加入白砂糖，轻轻搅拌到糖水变成黄色",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "倒入排骨翻炒30S后，加入生抽、蚝油、五香粉、蒜、小米椒后翻炒30S后，加入清水没过排骨",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "大火煮30分钟，加入老抽上色，再煮10分钟",
      "duration_minutes": 40,
      "tips": null
    },
    {
      "step": 6,
      "content": "起锅摆盘",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "增加味道的可以考虑加入豆瓣酱、番茄酱等",
    "大火煮时间可以根据每个人情况做调整",
    "煮排骨期间，可以顺道放入2-3个鸡蛋一起煮，做成简易版卤蛋"
  ]
}