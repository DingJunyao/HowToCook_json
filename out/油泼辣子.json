  "steps": [
    {
      "step": 1,
      "content": "拿出蒜头掰 2 个小蒜头去皮",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "拿出砧板剁碎小蒜头、小米椒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "拿出碗倒入花生油",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "油热放入其他配料和小葱，等到香料变焦，捞出扔掉",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "拿出铁锅将碗内的油放入加热 2 分钟（菜籽油烧至冒烟）",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "准备一个空碗，往空碗加入干辣椒面、白芝麻、蒜末、小米椒、盐、五香粉、草寇作为调料",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "关火将油温冷却至 210 摄氏度",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "将锅内热油倒入碗内并用勺子搅拌即可（可以在 165 摄氏度时加入同样调料的碗最后进行混合进行增辣）",
      "duration_minutes": 1,
      "tips": "可以在165摄氏度时加入同样调料的碗最后进行混合进行增辣"
    },
    {
      "step": 9,
      "content": "倒入热油稍微搅拌后放入白醋，此时会重新沸腾。继续进行搅拌，白醋增香。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "油泼辣子冷却到温热放白糖和味精，白糖可以是辣味柔和，不会那么的呛口",
      "duration_minutes": null,
      "tips": "白糖可以使辣味柔和，不会那么呛口"
    }
  ],
  "tips": [
    "五香粉、草寇作为调料加入，可以增加香味，使油泼辣子更香"
  ]
}