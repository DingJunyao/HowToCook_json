  "steps": [
    {
      "step": 1,
      "content": "取出平底锅（不沾平底锅最佳）",
      "duration_minutes": null,
      "tips": "不沾平底锅效果最佳"
    },
    {
      "step": 2,
      "content": "加入 10ml - 15ml 食用油",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "开火，放入饺子（尽量平均铺开，不宜堆叠）",
      "duration_minutes": null,
      "tips": "饺子需要平均铺开"
    },
    {
      "step": 4,
      "content": "立刻加入清水，水线没过饺子平均高度的 1/2",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "盖上锅盖，此时炉灶应该处于大火",
      "duration_minutes": null,
      "tips": "大火煮制"
    },
    {
      "step": 6,
      "content": "等待 8 - 10 分钟",
      "duration_minutes": 10,
      "tips": null
    },
    {
      "step": 7,
      "content": "当锅中水分仅剩 2mm 时，转中火开始煎制",
      "duration_minutes": null,
      "tips": "观察水分剩余情况"
    },
    {
      "step": 8,
      "content": "当水分全部蒸发后，摇晃平底锅使饺子受热均匀",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "放入黑芝麻和葱花再焖 10s",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "1 - 2 分钟夹出一个饺子观察底部，若出现金黄色脆皮立即取出",
      "duration_minutes": 2,
      "tips": "金黄色脆皮为最佳状态"
    }
  ],
  "tips": [
    "操作时，需时刻观察锅内情况，切记不可分神玩手机"
  ]
}