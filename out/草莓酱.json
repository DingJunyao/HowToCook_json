  "steps": [
    {
      "step": 1,
      "content": "草莓洗净去叶",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "将草莓切碎放入合适的碗中",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "将白糖倒入碗中与草莓搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "碗用保鲜膜覆盖静置1小时",
      "duration_minutes": 60,
      "tips": "静置可以让草莓出汁，与糖充分融合"
    },
    {
      "step": 5,
      "content": "将静置的草莓和糖的混合物倒入不粘锅中开大火烧开",
      "duration_minutes": 5,
      "tips": "使用不粘锅可以防止粘锅"
    },
    {
      "step": 6,
      "content": "烧开后转小火不断搅拌直至果酱呈粘稠状关火",
      "duration_minutes": 15,
      "tips": "需要持续搅拌防止糊底，观察果酱浓度"
    },
    {
      "step": 7,
      "content": "待草莓酱冷却后装入准备好的密封罐中",
      "duration_minutes": null,
      "tips": "冷却后装入密封罐可以延长保质期"
    }
  ],
  "tips": [
    "可以买那种一筐一筐卖的小草莓，主要是便宜",
    "做好的酱抹在面包上非常好吃"
  ]
}