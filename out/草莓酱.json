    },
    {
      "ingredient_name": "白砂糖",
      "quantity": 400,
      "unit": "g",
      "quantity_range": {
        "min": 200,
        "max": 400
      },
      "is_optional": false,
      "note": "如需要低糖饮食，可以考虑降低到200g",
      "original_quantity": null,
