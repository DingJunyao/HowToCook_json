  "steps": [
    {
      "step": 1,
      "content": "锅置旺火（大火）放入牛油烧至八成热(240±10°C)时放入老姜、大葱、洋葱、大蒜(各100g)，炸干（吸尽异味（牛油腥味））后捞出扔掉。",
      "duration_minutes": 10,
      "tips": "注意控制油温，避免过度加热"
    },
    {
      "step": 2,
      "content": "放入色拉油或菜籽油、纯猪油，等待锅中油温下降到五成热(150±10°C)时放入糍粑辣椒持续翻炒 5-8 分钟。",
      "duration_minutes": 8,
      "tips": null
    },
    {
      "step": 3,
      "content": "放入豆瓣酱炒散，转用中小火慢炒至料渣略发白翻砂（发出沙沙声）。",
      "duration_minutes": 15,
      "tips": "炒至料渣略发白翻砂是关键"
    },
    {
      "step": 4,
      "content": "油在外观呈现樱桃红时放入姜片(150g)、大蒜(100g)炒香，大约 15 秒。",
      "duration_minutes": 0.25,
      "tips": null
    },
    {
      "step": 5,
      "content": "放入豆豉、豆母子炒香，放入红花椒、小茴香炒香。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 6,
      "content": "此刻放入颗粒香料（制作老油时），或整形香料（制作底料时）。",
      "duration_minutes": 2,
      "tips": "颗粒香料需粉碎至 4mm 颗粒"
    },
    {
      "step": 7,
      "content": "放入麦芽粉炒散，放入白酒炒散。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 8,
      "content": "作为底料：起锅装入容器中，静置于温度低的环境(10-20) 5 天后再使用效果最佳。",
      "duration_minutes": null,
      "tips": "静置 5 天后风味更佳"
    },
    {
      "step": 9,
      "content": "作为老油：起锅装入容器中放入干辣椒面搅匀置放 24 小时，等待制作老油。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 10,
      "content": "将底料倒入锅中，加入 3/5 的开水用大火烧开（底料:2/5 开水:3/5）。",
      "duration_minutes": 5,
      "tips": "控制底料与开水的比例"
    },
    {
      "step": 11,
      "content": "烧开后表面会出现泡沫，将泡沫撇净。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 12,
      "content": "转用中小火慢熬出味（约 25-30 分钟），过滤去渣。",
      "duration_minutes": 30,
      "tips": null
    },
    {
      "step": 13,
      "content": "等待容器中油水分离后，将表面的油撇净（将油打出来）装入另外的容器。",
      "duration_minutes": 10,
      "tips": "等待完全油水分离"
    },
    {
      "step": 14,
      "content": "将上一步所撇出来的油重新倒入净锅中，直至炼干油中水分起锅装入容器即为火锅老油。",
      "duration_minutes": 10,
      "tips": "确保油中水分完全炼干"
    }
  ],
  "tips": [
    "操作时请擦干手上水滴！以免水进入油锅中发生爆炸！造成严重烧伤！"
  ]
}