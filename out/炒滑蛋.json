  "steps": [
    {
      "step": 1,
      "content": "鸡蛋加入牛奶以及 5ml 食用油搅拌均匀，备用",
      "duration_minutes": 1,
      "tips": "最好使用无菌蛋"
    },
    {
      "step": 2,
      "content": "大火烧热平底锅约 30s, 加入 5ml 食用油",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "烧 30s 转小火, 并且放入搅拌好的鸡蛋",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "在锅中静置 5 秒后，用锅铲将蛋液从边缘缓慢推向中间",
      "duration_minutes": 1,
      "tips": "小火操作，避免鸡蛋变老"
    },
    {
      "step": 5,
      "content": "翻炒至鸡蛋大致凝固后关火，装盘",
      "duration_minutes": 1,
      "tips": "鸡蛋大致凝固即可，避免炒得过老"
    }
  ],
  "tips": [
    "最好使用无菌蛋以确保安全",
    "最后可根据个人口味撒些黑胡椒或者盐来调味"
  ]
