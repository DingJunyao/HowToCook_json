  "steps": [
    {
      "step": 1,
      "content": "将西红柿洗净，切块。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "葱姜蒜切碎。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "鸡蛋打到碗中，用筷子（或打蛋器）搅拌均匀。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "热锅，并放入 15 毫升的油，待能从油中看到冒出一丝烟时，放入葱姜蒜翻炒 30 秒。",
      "duration_minutes": 2,
      "tips": "热油冒烟说明油温适宜"
    },
    {
      "step": 5,
      "content": "放入西红柿翻炒 1 分钟。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "倒入水，水的高度大约为锅内菜品高度的 1.2 倍，并放入盐。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 7,
      "content": "待开锅后，将鸡蛋液放入，并用筷子将鸡蛋打散，放入味素和香油。",
      "duration_minutes": 1,
      "tips": "一边倒入鸡蛋液一边快速搅拌，可形成漂亮的蛋花"
    },
    {
      "step": 8,
      "content": "等待 30 秒，关火出锅。",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "味素可加可不加"
  ]
}