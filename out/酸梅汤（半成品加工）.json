  "steps": [
    {
      "step": 1,
      "content": "取饮用水 1177 克。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "放入酸梅晶固体饮料 60 克，使用汤匙顺时针搅拌 50 圈。",
      "duration_minutes": 2,
      "tips": null
    },
