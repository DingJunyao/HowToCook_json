  "steps": [
    {
      "step": 1,
      "content": "将豆腐切成 2 cm 见方的小块，备用。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "锅中加入 500 ml 饮用水，大火烧开。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "放入豆腐块，煮 1-2 分钟，以去除豆腥味并使豆腐口感更紧实。",
      "duration_minutes": 1,
      "tips": "煮制时间不宜过长，以免豆腐碎裂"
    },
    {
      "step": 4,
      "content": "将煮好的豆腐块捞出，沥干水分，放入碗中，备用。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "将小葱洗净，切成葱花，备用。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "将大蒜去皮，切成蒜末，备用。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "在一个干净的小碗中，加入 15 ml 生抽，5 ml 香油，5 ml 醋（可选），2 g 白糖（可选）。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入切好的大蒜末。",
      "duration_minutes": 0,
      "tips": null
    },
    {
      "step": 9,
      "content": "搅拌均匀，使白糖充分溶解，酱汁混合均匀。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "将制作好的酱汁均匀淋在豆腐块上。",
      "duration_minutes": 0,
      "tips": null
    },
    {
      "step": 11,
      "content": "撒上切好的小葱花。",
      "duration_minutes": 0,
      "tips": null
    },
    {
      "step": 12,
      "content": "根据个人喜好，淋上 5 ml 辣椒油（可选）。",
      "duration_minutes": 0,
      "tips": null
    },
    {
      "step": 13,
      "content": "用筷子或勺子轻轻拌匀，即可食用。",
      "duration_minutes": 0,
      "tips": "动作要轻柔，避免把豆腐弄碎"
    }
  ],
  "tips": [
    "制作凉拌豆腐时，建议选用质地较硬的北豆腐或老豆腐，不易碎裂，口感更佳。",
    "如果喜欢更清淡的口感，可以省略醋和辣椒油。",
    "酱汁的比例可以根据个人口味进行调整。"
  ]
}