  "steps": [
    {
      "step": 1,
      "content": "准备食材",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "把豌豆淀粉和水各100克混合搅拌",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "往锅中倒入600g水，大火煮开后转为小火",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 4,
      "content": "倒入淀粉水，边倒边不断的搅拌，搅拌到浓稠且色泽均匀",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 5,
      "content": "找一个容器，在容器中刷一层薄薄的食用油",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "将煮好的淀粉倒入容器中冷藏2-4小时",
      "duration_minutes": null,
      "tips": "需冷藏2-4小时使其凝固"
    },
    {
      "step": 7,
      "content": "冷藏后取出，脱模，切条",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 8,
      "content": "大蒜和小米辣剁成沫，放上10g辣椒粉，5g花生碎，热油搅拌均匀",
      "duration_minutes": 5,
      "tips": "热油能激发辣椒和香料的香味"
    },
    {
      "step": 9,
      "content": "再加入10ml酱油，10ml醋，5g白糖，3g鸡精，3g盐搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 10,
      "content": "将调味料倒在凉粉上，然后撒上香菜即可",
      "duration_minutes": 2,
      "tips": null
    }
  ],
  "tips": [
    "参考：制作凉粉的详细步骤（https://www.zhms.cn/recipe/mzvyy.html?source=2）"
  ]
