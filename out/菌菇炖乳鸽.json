  "steps": [
    {
      "step": 1,
      "content": "冷水洗干净热心摊主处理好的乳鸽",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "冷水锅中放入洗干净的乳鸽，加入 7.5ml 料酒与部分姜，水煮开即可捞出乳鸽，要不然会丢失营养",
      "duration_minutes": 5,
      "tips": "水煮开后立即捞出乳鸽，避免营养流失"
    },
    {
      "step": 3,
      "content": "把乳鸽放到高压锅或者瓦罐中、倒入的水要没过乳鸽，放入生姜 10 g，玉米 100 g、菌菇 50 g",
      "duration_minutes": 5,
      "tips": "高压锅 30 分钟，瓦罐需在水烧开后转小火慢炖 40-60 分钟"
    },
    {
      "step": 4,
      "content": "时间到了，盛到碗中，加入 2~2.5g 盐 即可",
      "duration_minutes": 45,
      "tips": null
    }
  ],
  "tips": [
    "焯水时间不宜过长，水煮开后立即捞出乳鸽，避免营养流失",
    "使用高压锅炖制约需 30 分钟，使用瓦罐需在水烧开后转小火慢炖 40-60 分钟",
    "加水量要没过乳鸽"
  ]
