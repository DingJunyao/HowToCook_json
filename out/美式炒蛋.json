  "steps": [
    {
      "step": 1,
      "content": "鸡蛋打入大碗中，加盐搅打至起泡，静置 15 分钟",
      "duration_minutes": 15,
      "tips": null
    },
    {
      "step": 2,
      "content": "黄油切小块入锅，倒入蛋液，开小火不断搅拌",
      "duration_minutes": 3,
      "tips": "使用平底锅（不粘锅）"
    },
    {
      "step": 3,
      "content": "黄油一融化，就快速翻动蛋液，将其打碎成细密状，在蛋液大体凝固前关火",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入牛奶搅拌 15 秒，至炒蛋湿润绵密，装盘",
      "duration_minutes": 1,
      "tips": "考虑使用口径较小的锅，更方便在锅中均匀搅拌"
    }
  ],
  "tips": [
    "想吃的更丰富可以在最后一步加上炒好的番茄丁、洋葱丁、培根丁、切好的芝士小丁等（不要再出水的食材）"
  ]
}