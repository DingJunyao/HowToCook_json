  "steps": [
    {
      "step": 1,
      "content": "将切成半块的青柠之一切成小块，放入海波杯，随后用研杵将其捣出汁",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 2,
      "content": "用 3-4 珠薄荷叶沿着杯口涂抹，随后将其放入杯中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "加入糖浆 20ml",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入金色朗姆酒 45ml",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "将剩下的半块青柠压出汁水放入杯中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "轻轻搅拌，使砂糖/糖浆处于半融合状态",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "将打碎的冰块放入杯中，直到占杯中 3/4",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入冰镇苏打水直到刚好淹没碎冰",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "旋转搅拌半分钟",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 10,
      "content": "使用碎冰将海波杯补满",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 11,
      "content": "将剩下的一株薄荷叶拍醒，插入碎冰，作装饰",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
