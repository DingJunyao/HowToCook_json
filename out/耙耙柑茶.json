  "steps": [
    {
      "step": 1,
      "content": "称量 2~4 克茉莉绿茶置于容器，加入 100 毫升开水，泡 6 分钟",
      "duration_minutes": 6,
      "tips": "可按茶:水:冰 = 1~2 : 50 : 30 的比例调配"
    },
    {
      "step": 2,
      "content": "往泡好的绿茶中放入 60 克冰块冷却，可搅拌加速冷却，待冰块消失后将茶叶过滤得到茉莉绿茶茶水约 160 毫升",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "取出耙耙柑的肉瓣，剥去外皮，取 130 克果肉和 130 毫升茉莉绿茶放入搅拌机中",
      "duration_minutes": 2,
      "tips": "果肉和茶水比例为 1:1"
    },
    {
      "step": 4,
      "content": "倒入 10 克蔗糖糖浆（可选），封盖启动搅拌机，搅拌 20 秒后将搅拌产物倒入杯中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "取一点果肉撕碎撒在液面上",
      "duration_minutes": 1,
      "tips": "建议使用容量约 300 毫升的透明玻璃杯"
    }
  ],
  "tips": [
    "耙耙柑可以用其他容易分离果肉的柑橘替代，比如丑橘",
    "果肉和茶水比例为 1:1，如果需要配置更大的分量，可按比例提升用量"
  ]
}