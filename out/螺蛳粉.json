  "steps": [
    {
      "step": 1,
      "content": "锅中加水，将水烧开",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "下米粉，煮 3-5 分钟，期间用筷子搅拌，防止米粉粘在一起",
      "duration_minutes": 5,
      "tips": "如果想要更有嚼劲的粉，可以缩短煮粉的时间"
    },
    {
      "step": 3,
      "content": "下汤料包，按个人口味添加",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "下一部分配料包，如木耳，花生，螺蛳（这部分配料需要煮一会才入味）",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "下调味包（醋包、辣椒油），按个人口味添加，搅拌后捞出，放入碗中",
      "duration_minutes": 1,
      "tips": "配料的选择请依照个人口味"
    },
    {
      "step": 6,
      "content": "下剩下的配料包，如酸笋，豆皮（这部分配料不适合被汤泡太久），享用美食",
      "duration_minutes": 1,
      "tips": "如果想在螺蛳粉中添加炸蛋，请参考炸蛋的教程"
    }
  ],
  "tips": [
    "正宗的螺蛳粉是不臭的",
    "如果想要更有嚼劲的粉，可以缩短煮粉的时间",
    "如果想在螺蛳粉中添加炸蛋，请参考炸蛋的教程",
    "配料的选择请依照个人口味"
  ]
