  "steps": [
    {
      "step": 1,
      "content": "羊排放入碗中清水洗净血水",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "羊排用厨房纸吸干水分，双面抹上黑椒混合调味料、蒜蓉酱，静置腌制 20 分钟",
      "duration_minutes": 22,
      "tips": "双面都要抹上调料"
    },
    {
      "step": 3,
      "content": "锡纸碗放上烤架，羊排放在烤架上，撒上罗勒碎，黄油或烧烤料放在羊排上，空气炸锅 180° 10 分钟",
      "duration_minutes": 10,
      "tips": "可使用烤架，油比较少，底下更容易熟"
    },
    {
      "step": 4,
      "content": "羊排翻面，撒上罗勒碎，黄油（从锡纸碗里舀上来）或烧烤料放在羊排上，空气炸锅 180° 5 分钟",
      "duration_minutes": 5,
      "tips": "可以视个人喜好加一点时间，这里写的是不会焦的时间"
    }
  ],
  "tips": [
    "推荐购买温控比较好的空气炸锅，不然可能会糊",
    "使用烤架油比较少，底下更容易熟，但洗起来麻烦",
    "不用烤架比较入味，看个人选择"
  ]
}