  "steps": [
    {
      "step": 1,
      "content": "将生蚝用刷子刷干净（没有刷子用牙刷）",
      "duration_minutes": 3,
      "tips": "刷洗时要小心，不要把壳弄坏"
    },
    {
      "step": 2,
      "content": "蒸锅中放水，将蒸屉放上之后，将生蚝平铺在蒸屉，使用 50%功率，蒸 3 分钟",
      "duration_minutes": 4,
      "tips": null
    },
    {
      "step": 3,
      "content": "用湿抹布掀开烫锅盖，将每个生蚝的外壳掀开一半去掉，生蚝的凸面向下，平面向上，每个放 1 根姜丝，1g 蒜末放到生蚝上",
      "duration_minutes": 2,
      "tips": "使用湿抹布可以防止烫伤手部"
    },
    {
      "step": 4,
      "content": "关上烫锅盖，100%功率蒸 3.5 分钟",
      "duration_minutes": 4,
      "tips": "注意观察生蚝的状态，避免过度蒸制"
    },
    {
      "step": 5,
      "content": "停火，用湿抹布掀开烫锅盖，每个生蚝放 1ml 酱油",
      "duration_minutes": 1,
      "tips": "酱油用量可根据个人口味调整"
    },
    {
      "step": 6,
      "content": "盛盘",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "生蚝的壳很锋利，刷洗时要小心",
    "打开锅盖时务必使用湿抹布或隔热手套，防止烫伤",
    "蒸制时间不宜过长，否则生蚝会变得过老",
    "新鲜生蚝肉质饱满，品质较差的生蚝肉质松弛",
    "可根据个人口味增减酱油用量"
  ]
}