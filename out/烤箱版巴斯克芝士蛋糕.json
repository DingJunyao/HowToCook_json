  "steps": [
    {
      "step": 1,
      "content": "奶油奶酪软化，微波炉 10s + 10s",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "奶油奶酪加入白砂糖，打蛋器打至顺滑",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "加入 2 个全蛋 + 1 个蛋黄，搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入淡奶油，搅拌均匀",
      "duration_minutes": 2,
      "tips": "如果制作巧克力味，在此步骤将普通巧克力融化后加入搅拌均匀"
    },
    {
      "step": 5,
      "content": "加入低筋面粉，搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "烤箱 220°C(425°F)，烤制 20 - 25 分钟",
      "duration_minutes": 25,
      "tips": "本人一般烤 20 或者 22 分钟"
    },
    {
      "step": 7,
      "content": "放凉之后放入冰箱，最好过夜",
      "duration_minutes": 45,
      "tips": "烤箱出来成品抖动是正常的，放凉后口感还不是最好的，一定要冷藏才好吃"
