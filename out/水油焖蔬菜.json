  "steps": [
    {
      "step": 1,
      "content": "洗净蔬菜",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "锅中加入 150ml 水，并烧开（水不需要能完全没过蔬菜）",
      "duration_minutes": 2,
      "tips": null
    },
    {
