  "steps": [
    {
      "step": 1,
      "content": "烧开一锅水（水量能没过第 2-4 步中的食材即可）。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "在开水中放入青菜，焯 5 分钟后盛出备用。",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "在开水中放入无骨肉，焯 4 分钟后盛出备用。",
      "duration_minutes": 4,
      "tips": null
    },
    {
      "step": 4,
      "content": "在开水中放入北京麻辣方便面，煮 2 分钟后盛出备用。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "倒出开水，擦干锅具，放入 35 克食用油，大火加热 30 秒。",
      "duration_minutes": 1,
      "tips": "大火温度约 240 摄氏度，电磁炉功率约 2 千瓦"
    },
    {
      "step": 6,
      "content": "放入麻辣香锅调料，翻炒 20 秒。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "放入干辣椒，翻炒 10 秒。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "放入焯过的青菜，改中火，翻炒 3 分钟。",
      "duration_minutes": 3,
      "tips": "中火温度约 120 摄氏度，电磁炉功率约 1.4 千瓦"
    },
    {
      "step": 9,
      "content": "放入焯过的无骨肉，翻炒 3 分钟。",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 10,
      "content": "放入煮过的北京麻辣方便面，用筷子翻动 1 分钟。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 11,
      "content": "关火，出锅。",
      "duration_minutes": 0,
      "tips": null
    }
  ],
  "tips": [
    "大火通常温度在 240 摄氏度，以电磁炉为例，输入功率大约 2 千瓦",
    "中火通常温度在 120 摄氏度，以电磁炉为例，输入功率大约 1.4 千瓦"
  ]
}