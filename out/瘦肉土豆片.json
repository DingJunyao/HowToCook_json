  "steps": [
    {
      "step": 1,
      "content": "土豆去皮、对半切开，再切成约 2mm 的薄片，备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "蒜苗洗净，切成约 1cm 的段，备用",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 3,
      "content": "瘦肉洗净切成约 2mm 的薄片，放入碗中，加入 5g 生粉、5g 生抽、3g 老抽腌制十分钟，备用",
      "duration_minutes": 12,
      "tips": null
    },
    {
      "step": 4,
      "content": "瘦肉腌制时，烧一锅开水，将土豆片放入锅中，焯水，约 5 分钟",
      "duration_minutes": 6,
      "tips": "土豆片焯水注意不宜太久，防止土豆片变软"
    },
    {
      "step": 5,
      "content": "热锅，锅内放入 10ml - 15ml 食用油。等待 10 秒让油温升高",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "放入瘦肉，翻炒至变色，倒入蒜苗一起炒，蒜苗炒约 20 秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "放入土豆，保持翻炒，加入 2g 食用盐、5g 生抽",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "炒约 3 分钟，盛盘",
      "duration_minutes": 3,
      "tips": "腌制瘦肉要搅拌均匀"
    }
  ],
  "tips": [
    "土豆片焯水注意不宜太久，防止土豆片变软",
    "腌制瘦肉要搅拌均匀"
  ]
