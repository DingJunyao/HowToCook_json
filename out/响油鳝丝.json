  "steps": [
    {
      "step": 1,
      "content": "将鳝鱼切成三段后切成细丝",
      "duration_minutes": null,
      "tips": "鳝鱼可以让摊主帮忙宰杀"
    },
    {
      "step": 2,
      "content": "加入 2.5 g 香油、0.5 g 胡椒粉、3 g 料酒搅拌均匀，腌制鳝丝",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "热油滑锅",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入植物油，烧到 6 成热",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入一半蒜末和全部姜末，翻炒几下",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "加入鳝丝，中火爆炒 30 秒",
      "duration_minutes": null,
      "tips": "不能将鳝鱼的血洗得太干净，否则鳝鱼很容易发黑发臭"
    },
    {
      "step": 7,
      "content": "边缘淋入 10 g 料酒，翻炒几下",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入生抽，炒匀",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "加入蚝油、老抽，翻炒几下",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 10,
      "content": "加入食用盐、白糖、3 g 胡椒粉，炒匀",
      "duration_minutes": null,
      "tips": "可以多加一些胡椒粉和白糖，有利于去腥增香"
    },
    {
      "step": 11,
      "content": "淀粉和水混合为水淀粉，倒入锅中，收汁至浓稠",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 12,
      "content": "装盘，撒上蒜蓉、葱花",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 13,
      "content": "另起锅烧热，加入猪油，烧至七成热，浇在鳝丝上",
      "duration_minutes": null,
      "tips": "浇热猪油后香气扑鼻"
    }
  ],
  "tips": [
    "不能将鳝鱼的血洗得太干净，否则鳝鱼很容易发黑发臭",
    "鳝鱼可以让摊主帮忙宰杀",
    "可以多加一些胡椒粉和白糖，有利于去腥增香"
  ]
}