  "steps": [
    {
      "step": 1,
      "content": "200g 白芸豆提前一晚清水浸泡备用",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "准备猪前蹄，买菜的时候让师傅从中间劈开，用喷火枪去除毛囊，拿回家清洗",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "冷水锅中加入猪蹄、大葱段、姜片、料酒，焯水十分钟，撇去浮沫，捞出洗干净备用",
      "duration_minutes": 10,
      "tips": "焯水十分钟，撇去浮沫"
    },
    {
      "step": 4,
      "content": "高压锅中放入猪蹄、当归、白芷、白胡椒粉、姜片，上汽后压三十分钟，放入白芸豆，再压十分钟，这个时候如果汤底是奶白色，那么恭喜是正确的",
      "duration_minutes": 40,
      "tips": "如果中途需要加水，只能加热水；汤底应该是奶白色"
    },
    {
      "step": 5,
      "content": "揭盖后加入盐、鸡精、葱花调味",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "调制灵魂汁子：放入葱、蒜、小米椒，白胡椒粉、生抽、香醋、油泼辣子、花椒油、猪蹄原汤",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "灵魂汁子，浇给",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": []
