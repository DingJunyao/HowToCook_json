  "steps": [
    {
      "step": 1,
      "content": "用冷水将鸡蛋煮熟，大火大约 8 分钟（根据自家厨具决定）",
      "duration_minutes": 8,
      "tips": null
    },
    {
      "step": 2,
      "content": "鸡蛋捞出，过冷水",
      "duration_minutes": null,
      "tips": "让鸡蛋和壳之间产生间隙"
    },
    {
      "step": 3,
      "content": "将鸡蛋互相碰撞，使每个鸡蛋产生裂缝",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "将鸡蛋下锅，放入八角，香叶，桂皮，茴香，冰糖，红茶，生抽，老抽，食盐",
      "duration_minutes": null,
      "tips": "自己没有这么多食材可以买现成的卤料包"
    },
    {
      "step": 5,
      "content": "加水直至没过鸡蛋",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "大火煮开之后，转中小火煮 15 分钟",
      "duration_minutes": 15,
      "tips": "煮完之后，捞出料渣，鸡蛋再浸泡一会口感更佳"
    }
  ],
  "tips": [
    "鸡蛋捞出过冷水是为了让鸡蛋和壳之间产生间隙",
