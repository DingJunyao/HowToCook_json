  "steps": [
    {
      "step": 1,
      "content": "青菜掰成小瓣，用清水洗净，备用。",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "中火或大火热锅后，锅内放入 10-15ml 食用油。再等待 30 秒让油温升高。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "将准备好的青菜倒入锅中，翻炒至青菜变软（约 1 分钟）。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "倒入计算好的清水，水位应当完全浸润或即将没过青菜，加入食盐 2g，继续翻炒约 1 分钟。",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 5,
      "content": "加入白糖小火加热 2 分钟，加热时盖上锅盖。",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 6,
      "content": "盛盘。",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "加入白糖，会让青菜颜色更绿。"
  ]
}