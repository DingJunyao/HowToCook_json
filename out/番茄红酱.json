  "steps": [
    {
      "step": 1,
      "content": "将胡萝卜、芹菜、洋葱切碎，蒜瓣切片",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 2,
      "content": "加入 10ml 橄榄油，热油下锅蔬菜，大火翻炒开始略微变色后盛出",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 3,
      "content": "锅内加油 10ml，加蒜翻炒 10 秒，加入碎牛肉、糖、盐、胡椒粉和香料将牛肉炒脆（有颗粒感）",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入炒好的蔬菜们和番茄酱继续翻炒，搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "分多次缓缓倒入牛奶，中小火煮 30 分钟，完成",
      "duration_minutes": 30,
      "tips": "煮酱料期间请搅动，以免粘锅。如果酱料变粘稠就可以出锅啦！"
    }
  ],
  "tips": [
    "考虑各个品牌的番茄酱内含盐量不同，建议在炒牛肉时少放盐，煮的时候尝一下再调味",
    "煮酱料期间请搅动，以免粘锅。如果酱料变粘稠就可以出锅啦！",
    "可根据个人口味，将碎牛肉替换成一半碎猪肉一半碎牛肉，牛奶替换成鸡汤或饮用水"
  ]
