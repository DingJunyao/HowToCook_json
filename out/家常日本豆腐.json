  "steps": [
    {
      "step": 1,
      "content": "胡萝卜切片，尖椒切薄块，葱蒜碎切好",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "把买好的日本豆腐打开袋子切好，切成大概 1 cm 厚的圆柱体",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 3,
      "content": "生粉放到平盘中，准备给豆腐裹面",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "轻轻把豆腐放到面粉上，上下两面和周边都裹上面粉，注意不要包裹的太厚",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 5,
      "content": "在平底锅里放 75 ml 油，油能没过豆腐一大半即可，看边缘颜色变成金黄，翻面煎就可以了",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 6,
      "content": "两边都煎好的时候捞出来放在干净的盘里备用",
      "duration_minutes": null,
      "tips": "煎好的豆腐不要放太久"
    },
    {
      "step": 7,
      "content": "在炒锅中倒入 5-7.5 ml 油，放入葱蒜，爆香后放入青椒、胡萝卜、火腿肠、黑木耳",
      "duration_minutes": null,
      "tips": "提前准备好配料"
    },
    {
      "step": 8,
      "content": "加入蚝油、生抽、盐、鸡精、白砂糖、番茄酱",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 9,
      "content": "轻轻翻炒至颜色均匀",
      "duration_minutes": null,
      "tips": null
    }
  ],
  "tips": [
    "煎好的豆腐不要放太久，提前准备好配料",
