  "steps": [
    {
      "step": 1,
      "content": "将米淘洗干净后倒入饭碗内，加入 400ml 的水，盖上盖",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "放入微波炉，高火 6 分钟，煮饭途中准备原料：切好腊肠、洗好青菜、切好红萝卜片、切好葱花。青菜碗中放入青菜、红萝卜片，倒入 10 ml 油，放入 5 g 盐。小碗中倒入 10 ml 生抽、5 ml 油",
      "duration_minutes": 6,
      "tips": "煮饭途中可以准备其他食材"
    },
    {
      "step": 3,
      "content": "6 分钟后，用毛巾或隔热手套取出碗，在米饭上摆入切片的腊肠，继续高火 2 分钟",
      "duration_minutes": 2,
      "tips": "用毛巾或隔热手套取出碗以防烫伤"
    },
    {
      "step": 4,
      "content": "取出腊肠饭，放入青菜碗，高火 4-5 分钟",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 5,
      "content": "在腊肠饭上摆好青菜，磕入鸡蛋，看个人喜好继续高火 40-60 秒",
      "duration_minutes": 1,
      "tips": "根据个人喜好调整时间"
    },
    {
      "step": 6,
      "content": "取出腊肠饭，此时已经基本完成。将小碗放入，继续高火 30 秒",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 7,
      "content": "在腊肠饭上淋上叮热的生抽，撒上葱花即可",
      "duration_minutes": null,
      "tips": "多余的青菜可以沾着酱油吃"
    }
  ],
