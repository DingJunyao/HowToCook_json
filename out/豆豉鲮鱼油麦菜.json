  "steps": [
    {
      "step": 1,
      "content": "油麦菜洗净后切段",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "鲮鱼罐头打开后，把鲮鱼主刺去除，切成小段后备用",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "大蒜切成末",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 4,
      "content": "锅热倒入食用油，油热后加入洗净的油麦菜，炒到萎蔫出水后盛出备用，倒掉炒制出的水分",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 5,
      "content": "重新热锅后，加入鲮鱼罐头中的油，放入蒜末煸香",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 6,
      "content": "蒜末煸香后加入鲮鱼罐头中的豆豉，翻拌后加入切碎的鲮鱼块，再次翻拌",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 7,
      "content": "翻拌均匀后加入油麦菜，加入生抽和糖调味",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "调味加入后简单翻拌即可出锅装盘",
      "duration_minutes": 1,
      "tips": null
    }
  ],
  "tips": [
    "鲮鱼罐头本身带味道，加入生抽后够味，无需下盐"
  ]
