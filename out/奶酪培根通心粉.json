  "steps": [
    {
      "step": 1,
      "content": "将奶酪磨成碎末，洋葱切成条状，大蒜切碎",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "用微咸的水煮通心粉 6 分钟",
      "duration_minutes": 6,
      "tips": null
    },
    {
      "step": 3,
      "content": "中火锅中放入黄油，等待融化",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入洋葱，等待软化",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 5,
      "content": "洋葱软化后加入大蒜",
      "duration_minutes": 1,
      "tips": "等待大蒜香味出来"
    },
    {
      "step": 6,
      "content": "加入培根或其他肉类，等待 5 秒",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 7,
      "content": "转小火，分四次加入牛奶，每次搅拌 5 秒后再加下一次",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 8,
      "content": "加入面粉并充分搅拌",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 9,
      "content": "加入奶酪并搅拌均匀",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 10,
      "content": "将通心粉和奶酪搅拌",
      "duration_minutes": 2,
      "tips": "如果不打算烘烤，可以直接吃了"
    },
    {
      "step": 11,
      "content": "预热烤箱至 180°C",
      "duration_minutes": 5,
      "tips": "可选步骤"
    },
    {
      "step": 12,
      "content": "将额外的芝士铺在通心粉之上",
      "duration_minutes": 1,
      "tips": "可选步骤"
    },
    {
      "step": 13,
      "content": "等待烤箱预热至 180°C 后，将通心粉放入，烤至表面金黄",
      "duration_minutes": 24,
      "tips": "可选步骤"
    }
  ],
  "tips": [
    "本料理及其不健康，有大约 1300 大卡，80g 脂肪，不建议常吃"
  ]
