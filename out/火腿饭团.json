  "steps": [
    {
      "step": 1,
      "content": "将米饭和水放到电饭锅里，点击米饭模式，等待完成",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 2,
      "content": "冷冻玉米粒和青豆放到锅里，加水没过所有食材，沸腾后静待 2 分钟后，捞出",
      "duration_minutes": 5,
      "tips": "焯水使蔬菜更软嫩"
    },
    {
      "step": 3,
      "content": "火腿切成 1cm 的方块",
      "duration_minutes": null,
      "tips": null
    },
    {
      "step": 4,
      "content": "加入 5ml 食用油，加入火腿翻炒至火腿上色",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 5,
      "content": "将米饭，火腿，海苔碎，青豆，玉米粒，沙拉酱放入碗中，混合均匀即可",
      "duration_minutes": null,
      "tips": null
    },
