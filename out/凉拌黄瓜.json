  "steps": [
    {
      "step": 1,
      "content": "用菜刀将黄瓜拍扁，再剁成长 3 厘米的碎块",
      "duration_minutes": 2,
      "tips": null
    },
    {
      "step": 2,
      "content": "将碎黄瓜装入碗中",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 3,
      "content": "将蒜拍碎切成碎末",
      "duration_minutes": 1,
      "tips": null
    },
    {
      "step": 4,
      "content": "将醋、酱油、盐、蚝油和蒜依次倒入碗中搅拌均匀并腌制 15 分钟",
      "duration_minutes": 15,
      "tips": null
    },
    {
      "step": 5,
      "content": "将香油倒入碗中并均匀搅拌",
      "duration_minutes": 1,
      "tips": null
    }
