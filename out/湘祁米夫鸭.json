  "steps": [
    {
      "step": 1,
      "content": "将糯米粉、粘米粉、蒸肉粉、细辣椒粉、盐、白胡椒粉倒一起搅匀",
      "duration_minutes": 3,
      "tips": null
    },
    {
      "step": 2,
      "content": "鸭子让摊主剁成蒸煮块，姜切片，蒜子剥皮，五花肉切片即可",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 3,
      "content": "热锅凉油煸炒五花肉出油，再加食用油烧热，下入鸭子煸炒",
      "duration_minutes": 8,
      "tips": "五花肉可选"
    },
    {
      "step": 4,
      "content": "鸭子煸炒到表皮焦变色，下入姜蒜和剩余盐继续煸炒出香味",
      "duration_minutes": 5,
      "tips": null
    },
    {
      "step": 5,
      "content": "关小火倒入米粉翻炒，使鸭肉均匀裹满米粉子，加入开水少量多次边加边翻炒",
      "duration_minutes": 5,
      "tips": "保持小火，米粉要均匀裹上鸭肉"
    },
    {
      "step": 6,
      "content": "翻炒至鸭肉和米粉有湿感，铲出入碗中，高压锅放水蒸20-25分钟",
      "duration_minutes": 25,
      "tips": "是老鸭的话，蒸一个小时以上"
    },
    {
      "step": 7,
      "content": "出锅前撒点葱花即可享用",
      "duration_minutes": 1,
      "tips": "葱花可选"
    }
  ],
  "tips": [
    "鸭子品种不限，这里用的是水鸭",
    "蒸20分钟，是老鸭的话，蒸一个小时以上",
    "粘米粉是主要的粉子，糯米粉是加软糯口感，蒸肉粉是加五香味道，辣椒粉和胡椒粉是加复合香味"
  ]
}